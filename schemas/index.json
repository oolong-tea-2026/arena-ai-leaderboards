{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arena Daily Index",
  "description": "Summary of a daily leaderboard fetch run",
  "type": "object",
  "required": ["date", "fetched_at", "leaderboards"],
  "additionalProperties": false,
  "properties": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "fetched_at": { "type": "string", "format": "date-time" },
    "leaderboards": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["model_count"],
        "properties": {
          "model_count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["leaderboard", "error"],
        "properties": {
          "leaderboard": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    }
  }
}
